[csgm]
dataset = "fashion-mnist"
checkpoint = "outputs/vae_fashion_mnist/vae_fashion_mnist_best.pt"
data_dir = "data"
output_dir = "outputs/cs_comparison_fashion_mnist"

# Empty measurements means: use max_measurements and measurement_step.
measurements = []
max_measurements = 100
measurement_step = 5

num_samples = 10
batch_size = 8
num_workers = 2
noise_std = 0.0

lasso_alpha = 0.001
lasso_max_iter = 5000
lasso_tol = 0.0001

vae_steps = 1000
vae_restarts = 5
vae_lr = 0.05
vae_log_interval = 0

z_prior_weight = "none"
measurement_policy = "both"
candidate_measurements = 784

active_refit_steps = 500
active_refit_interval = 5
active_progress_interval = 5
active_restarts = 1

acquisition_prior_precision = 1.0
acquisition_noise_var = 0.01

latent_dim = 64
hidden_dim = "auto"
device = "auto"
seed = 42
grid_images = 8
no_download = true
